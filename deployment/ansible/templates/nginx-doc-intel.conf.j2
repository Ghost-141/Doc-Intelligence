limit_req_zone $binary_remote_addr zone=doc_intel:10m rate={{ doc_intel_nginx_rate_limit }};

server {
    listen 80;
    server_name {{ doc_intel_server_name }};

    client_max_body_size {{ doc_intel_client_max_body_size }};

    location / {
        limit_req zone=doc_intel burst={{ doc_intel_nginx_rate_burst }} nodelay;
        limit_req_status 429;

        proxy_pass http://{{ doc_intel_api_host }}:{{ doc_intel_api_port }};
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 60;
        proxy_send_timeout 300;
        proxy_read_timeout 300;
    }
}
